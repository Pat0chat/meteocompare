<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Permissions minimales — strictement nécessaires au fonctionnement.
        INTERNET : requise pour les requêtes Open-Meteo (seul backend utilisé).
        ACCESS_NETWORK_STATE : pour des futures fonctionnalités offline-aware
        (afficher un bandeau "hors-ligne"). Ne donne accès à aucune donnée perso.
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
        Suppression EXPLICITE de la permission AD_ID (Advertising ID).
        Certaines libs Google Play Services l'ajoutent automatiquement via
        manifest merger. On la retire pour garantir l'absence totale de
        tracking publicitaire et pour déclarer "no ad ID" dans Play Console.
    -->
    <uses-permission
        android:name="com.google.android.gms.permission.AD_ID"
        tools:node="remove" />

    <application
        android:name=".MeteoCompareApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MeteoCompare">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MeteoCompare">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
