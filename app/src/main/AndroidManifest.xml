<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Permissions minimales — strictement nécessaires au fonctionnement.
        INTERNET : requise pour les requêtes Open-Meteo (seul backend utilisé).
        ACCESS_NETWORK_STATE : pour des futures fonctionnalités offline-aware
        (afficher un bandeau "hors-ligne"). Ne donne accès à aucune donnée perso.
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
        Pas de Google Play Services / Firebase / AdMob dans les dépendances,
        donc rien n'injecte la permission AD_ID (Advertising ID). Inutile d'avoir
        un tools:node="remove" — il déclencherait un warning manifest-merger
        ("tagged to remove other declarations but no other declaration present").
        Si une future dépendance l'ajoutait, on remettrait la suppression ici.
    -->

    <application
        android:name=".MeteoCompareApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MeteoCompare">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MeteoCompare.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Per-app language preferences via AppCompat.
            On utilise AppCompatDelegate.setApplicationLocales() pour changer
            la langue à l'exécution. AppCompat a besoin de connaître ce service
            (qui ne tourne jamais — il sert juste de metadata holder) pour
            persister automatiquement le choix de langue à travers les cold
            starts. Sans ça, le toggle change la langue pour la session courante
            mais l'app revient à la langue système au prochain démarrage.
            Voir : https://developer.android.com/guide/topics/resources/app-languages
        -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

    </application>

</manifest>
